<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.web.WebView?>
<BorderPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="projector.controller.BrowserController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="5.0" left="10.0" right="10.0" top="5.0"/>
            </padding>
            <TextField fx:id="urlTextField" promptText="Enter URL (e.g. https://example.com)" prefWidth="350.0"/>
            <Button mnemonicParsing="false" onAction="#onGo" text="Go"/>
            <Button mnemonicParsing="false" onAction="#onCastFullPage" text="Cast full page"/>
            <ToggleButton fx:id="selectRegionToggle" mnemonicParsing="false" onAction="#onSelectRegionToggle"
                          text="Select region"/>
            <ToggleButton fx:id="selectImageToggle" mnemonicParsing="false" onAction="#onSelectImageToggle"
                          text="Select image"/>
        </HBox>
    </top>
    <center>
        <StackPane fx:id="webViewStackPane">
            <WebView fx:id="webView"/>
        </StackPane>
    </center>
</BorderPane>
