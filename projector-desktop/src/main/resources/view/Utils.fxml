<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<BorderPane prefHeight="560" prefWidth="800" styleClass="border-pane" xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="projector.controller.UtilsController">
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" maxHeight="Infinity"
                    BorderPane.alignment="CENTER">
            <VBox alignment="TOP_CENTER" spacing="16.0">
                <padding>
                    <Insets bottom="16.0" left="16.0" right="16.0" top="12.0"/>
                </padding>
                <HBox alignment="CENTER" prefHeight="50.0" spacing="10.0">
                    <TextField fx:id="timeTextField" prefHeight="25.0" prefWidth="50.0" text="15:45"/>
                    <Button mnemonicParsing="false" onAction="#onShowCountDownButtonEvent" text="Show countdown"/>
                    <Label fx:id="countDownLabel" text="04:59"/>
                    <Label text="%Show finish time"/>
                    <CheckBox fx:id="showFinishTimeCheckBox"/>
                    <Label text="%Trigger action:"/>
                    <ComboBox fx:id="actionComboBox" prefWidth="110.0"/>
                    <Label text="Screens:"/>
                    <ComboBox fx:id="projectionScreensComboBox"/>
                </HBox>
                <Separator maxWidth="Infinity"/>
                <VBox spacing="14.0" styleClass="utils-qr-section">
                    <Label styleClass="utils-section-heading" text="%QrCodeSection"/>
                    <VBox spacing="10.0">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label minWidth="96.0" text="%QrTitle"/>
                            <TextField fx:id="qrTitleTextField" maxWidth="Infinity" promptText="%QrTitlePrompt"
                                       HBox.hgrow="ALWAYS"/>
                        </HBox>
                        <HBox spacing="10.0">
                            <Label minWidth="96.0" text="%QrDescription"/>
                            <TextArea fx:id="qrDescriptionTextArea" maxHeight="72.0" maxWidth="Infinity"
                                      prefRowCount="3"
                                      promptText="%QrDescriptionPrompt" wrapText="true" HBox.hgrow="ALWAYS"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label minWidth="96.0" text="%QrContent"/>
                            <TextField fx:id="qrContentTextField" maxWidth="Infinity" promptText="%QrContentPrompt"
                                       HBox.hgrow="ALWAYS"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Button mnemonicParsing="false" onAction="#onGenerateQrButtonEvent" text="%GenerateQr"/>
                            <Button fx:id="saveQrPngButton" disable="true" mnemonicParsing="false"
                                    onAction="#onSaveQrPngButtonEvent" text="%SaveQrPng"/>
                        </HBox>
                    </VBox>
                    <Separator maxWidth="Infinity"/>
                    <HBox alignment="CENTER">
                        <StackPane styleClass="utils-qr-preview-frame">
                            <ImageView fx:id="qrImageView" cache="true" fitHeight="280.0" fitWidth="280.0"
                                       pickOnBounds="true" preserveRatio="true"/>
                        </StackPane>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
